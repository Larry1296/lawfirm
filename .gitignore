# ===============================
# OS / SYSTEM FILES
# ===============================
.DS_Store
Thumbs.db

# ===============================
# ENV FILES (IMPORTANT)
# ===============================
.env
.env.*
*.env

# ===============================
# PYTHON / DJANGO
# ===============================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
env/
.venv/

# Django stuff
*.log
*.pot
*.pyc
db.sqlite3
db.sqlite3-journal

# Static & media (generated)
staticfiles/
media/

# Migrations (optional — keep if working in team)
**/migrations/*
!**/migrations/__init__.py

# ===============================
